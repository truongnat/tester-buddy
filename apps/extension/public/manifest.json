{
  "manifest_version": 3,
  "name": "TesterBuddy",
  "version": "0.1.0",
  "description": "Browser-Connected QA Assistant",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "unlimitedStorage",
    "offscreen",
    "tabCapture",
    "desktopCapture"
  ],
  "host_permissions": [
    "http://127.0.0.1:17393/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TesterBuddy"
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
